<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Profile Details & History Table   -->
<!-- [FUNCTIONAL LOGIC] - Renders Vehicle Specs & Battery Logs-->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Vehicle Details</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App</a>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <div class="container mt-4 mb-5" style="max-width: 800px;">
    <!-- [DESIGN] Vehicle Profile Summary Card -->
    <div class="card shadow-sm border-0 rounded-4 p-4 bg-white mb-4">
      <div class="row align-items-center">
        <% if (vehicle.image) { %>
          <div class="col-md-5">
            <img src="/images/<%= vehicle.image %>" class="img-fluid rounded-3 shadow-sm" alt="Vehicle Image">
          </div>
        <% } %>
        <div class="col">
          <h2 class="fw-bold mb-2"><%= vehicle.model %></h2>
          <p class="text-muted mb-1">Plate Number: <strong><%= vehicle.plateNumber %></strong></p>
          <p class="text-muted mb-1">Current Battery Health: <strong><%= vehicle.batteryHealth %>%</strong></p>
          <p class="text-muted mb-3">Current Mileage: <strong><%= vehicle.mileage %> km</strong></p>
          <a href="/addBatteryLog/<%= vehicle.vehicleId %>" class="btn btn-dark btn-sm fw-semibold">➕ Add Battery Log Entry</a>
        </div>
      </div>
    </div>

    <!-- [FUNCTION] Battery History Logs Data Table -->
    <h4 class="mb-3 text-secondary">Battery History Logs</h4>
    <div class="card shadow-sm border-0 rounded-4 p-3 bg-white">
      <% if (logs.length === 0) { %>
        <p class="text-muted mb-0">No history logs recorded yet.</p>
      <% } else { %>
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <th>Date</th>
              <th>Battery Health</th>
              <th>Mileage</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% for(let i=0; i<logs.length; i++) { %>
              <tr>
                <td><%= new Date(logs[i].logDate).toLocaleDateString() %></td>
                <td><%= logs[i].batteryHealth %>%</td>
                <td><%= logs[i].mileage %> km</td>
                <td><a href="/deleteLog/<%= logs[i].logId %>" class="btn btn-sm btn-outline-danger">Delete</a></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>