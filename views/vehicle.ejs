<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">EV App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <% if (user.role === 'admin') { %>
                <a class="nav-link" href="/adminDashboard">Back to Dashboard</a>
              <% } else { %>
                <a class="nav-link" href="/dashboard">Back to Dashboard</a>
              <% } %>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container mt-4">
    <h2 class="text-center"><%= vehicle.model %> (<%= vehicle.plateNumber %>)</h2>

    <% if (vehicle.image) { %>
      <div class="text-center mb-3">
        <img src="/images/<%= vehicle.image %>" class="img-thumbnail" style="max-width: 300px;">
      </div>
    <% } %>

    <div class="row text-center mt-3">
      <div class="col">
        <div class="card">
          <div class="card-body">
            <h5>Current Battery Health</h5>
            <div class="progress" style="height: 30px;">
              <div class="progress-bar
                <% if (vehicle.batteryHealth >= 90) { %>bg-success
                <% } else if (vehicle.batteryHealth >= 80) { %>bg-warning
                <% } else { %>bg-danger<% } %>"
                role="progressbar"
                style="width: <%= vehicle.batteryHealth %>%;">
                <%= vehicle.batteryHealth %>%
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card">
          <div class="card-body">
            <h5>Current Mileage</h5>
            <p class="fs-3"><%= vehicle.mileage %> km</p>
          </div>
        </div>
      </div>
    </div>

    <br>
    <div class="text-center"><h3>Battery Health History</h3></div>
    <p class="text-center"><a href="/addBatteryLog/<%= vehicle.vehicleId %>" class="btn btn-primary">Add New Log Entry</a></p>

    <% if (logs.length === 0) { %>
      <p class="text-center">No log entries yet.</p>
    <% } else { %>
      <table class="table table-hover small text-center">
        <thead>
            <tr>
              <th>Date</th>
              <th>Battery Health</th>
              <th>Mileage (km)</th>
              <th>Actions</th>
            </tr>
        </thead>
        <tbody>
          <% for(let i = 0; i < logs.length; i++) { %>
            <tr>
              <td><%= logs[i].logDate.toISOString().split('T')[0] %></td>
              <td>
                <div class="progress" style="height: 20px;">
                  <div class="progress-bar
                    <% if (logs[i].batteryHealth >= 90) { %>bg-success
                    <% } else if (logs[i].batteryHealth >= 80) { %>bg-warning
                    <% } else { %>bg-danger<% } %>"
                    role="progressbar"
                    style="width: <%= logs[i].batteryHealth %>%;">
                    <%= logs[i].batteryHealth %>%
                  </div>
                </div>
              </td>
              <td><%= logs[i].mileage %></td>
              <td>
                <a href="/deleteLog/<%= logs[i].logId %>" class="btn btn-sm btn-danger">Delete</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
