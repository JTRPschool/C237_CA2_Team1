<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App - Admin</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">EV App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addStation">Add Charging Station</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/searchVehicles">Search Fleet</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container">
    <p class="mt-3">Welcome, <%= user.username %> (<%= user.role %>)</p>

    <div class="text-center"><h2>Fleet Analytics</h2></div>
    <div class="row text-center mt-3">
      <div class="col">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Total Vehicles</h5>
            <p class="card-text fs-3"><%= totalVehicles %></p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Average Battery Health</h5>
            <p class="card-text fs-3"><%= avgHealth %>%</p>
          </div>
        </div>
      </div>
      <div class="col">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Total Charging Stations</h5>
            <p class="card-text fs-3"><%= stations.length %></p>
          </div>
        </div>
      </div>
    </div>

    <br>
    <div class="text-center"><h2>All Vehicles in Fleet</h2></div>
    <br>
    <table class="table table-hover small text-center">
      <thead>
          <tr>
            <th>Owner</th>
            <th>Model</th>
            <th>Plate Number</th>
            <th>Battery Health</th>
            <th>Mileage (km)</th>
            <th>Actions</th>
          </tr>
      </thead>
      <tbody>
        <% for(let i = 0; i < vehicles.length; i++) { %>
          <tr>
            <td><%= vehicles[i].username %></td>
            <td><a href="/vehicle/<%= vehicles[i].vehicleId %>"><%= vehicles[i].model %></a></td>
            <td><%= vehicles[i].plateNumber %></td>
            <td>
              <div class="progress" style="height: 20px;">
                <div class="progress-bar
                  <% if (vehicles[i].batteryHealth >= 90) { %>bg-success
                  <% } else if (vehicles[i].batteryHealth >= 80) { %>bg-warning
                  <% } else { %>bg-danger<% } %>"
                  role="progressbar"
                  style="width: <%= vehicles[i].batteryHealth %>%;">
                  <%= vehicles[i].batteryHealth %>%
                </div>
              </div>
            </td>
            <td><%= vehicles[i].mileage %></td>
            <td>
              <a href="/deleteVehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-danger">Delete</a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <br>
    <div class="text-center"><h2>Charging Stations</h2></div>
    <br>
    <table class="table table-hover small text-center">
      <thead>
          <tr>
            <th>Station Name</th>
            <th>Location</th>
            <th>Available</th>
          </tr>
      </thead>
      <tbody>
        <% for(let i = 0; i < stations.length; i++) { %>
          <tr>
            <td><%= stations[i].stationName %></td>
            <td><%= stations[i].location %></td>
            <td><%= stations[i].available %></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</body>
</html>
