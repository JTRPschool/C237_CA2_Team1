<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Admin Portal Analytics & Tables   -->
<!-- [FUNCTIONAL LOGIC] - Renders Fleet Stats, Stations, Users -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Admin Dashboard</title>
</head>
<body class="bg-light">
  <!-- [AESTHETIC] Top Navigation Bar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ Admin Portal</a>
      <div class="ms-auto">
        <a href="/searchVehicles" class="btn btn-outline-light btn-sm me-2">🔍 Search Vehicles</a>
        <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
      </div>
    </div>
  </nav>

  <!-- [DESIGN] Main Container Body -->
  <div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Fleet Management (Admin)</h2>
      <a href="/addStation" class="btn btn-dark btn-sm fw-semibold">➕ Add Charging Station</a>
    </div>

    <!-- [DESIGN] Analytics Cards Grid Layout -->
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
          <h6 class="text-muted">Total Fleet Vehicles</h6>
          <h2 class="fw-bold"><%= totalVehicles %></h2>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card shadow-sm border-0 rounded-4 p-4 bg-white">
          <h6 class="text-muted">Average Battery Health</h6>
          <h2 class="fw-bold"><%= avgHealth %>%</h2>
        </div>
      </div>
    </div>

    <!-- [FUNCTION] Charging Stations List Table -->
    <h4 class="mb-3 text-secondary">Charging Stations</h4>
    <div class="card shadow-sm border-0 rounded-4 p-3 bg-white mb-4">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Station Name</th>
            <th>Location</th>
            <th>Available</th>
          </tr>
        </thead>
        <tbody>
          <% for(let i=0; i<stations.length; i++) { %>
            <tr>
              <td><%= stations[i].stationName %></td>
              <td><%= stations[i].location %></td>
              <td><span class="badge bg-<%= stations[i].available === 'yes' ? 'success' : 'danger' %>"><%= stations[i].available %></span></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- [FUNCTION] All User Fleet Vehicles Table -->
    <h4 class="mb-3 text-secondary">All User Vehicles</h4>
    <div class="card shadow-sm border-0 rounded-4 p-3 bg-white">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Owner</th>
            <th>Model</th>
            <th>Plate</th>
            <th>Battery Health</th>
            <th>Mileage</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for(let i=0; i<vehicles.length; i++) { %>
            <tr>
              <td><%= vehicles[i].username %></td>
              <td><%= vehicles[i].model %></td>
              <td><%= vehicles[i].plateNumber %></td>
              <td><%= vehicles[i].batteryHealth %>%</td>
              <td><%= vehicles[i].mileage %> km</td>
              <td>
                <a href="/vehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-dark">View</a>
                <a href="/deleteVehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-outline-danger">Delete</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>