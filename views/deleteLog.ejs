<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark"><div class="container-fluid"><a class="navbar-brand" href="/">EV App</a></div></nav>
  <div class="container mt-4 mx-auto text-center" style="max-width: 500px;">
    <h2 class="text-danger mb-4">Delete Battery Log</h2>
    <p>Are you sure you want to delete log <strong>#<%= log.logId %></strong>?</p>
    <form action="/deleteLog/<%= log.logId %>" method="POST">
      <div class="d-grid gap-2 mt-4">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/vehicle/<%= log.vehicleId %>" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>