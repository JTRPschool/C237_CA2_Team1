<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Reschedule Form Card Layout       -->
<!-- [FUNCTIONAL LOGIC] - Updates slot schedule and status    -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Reschedule Session</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid"><a class="navbar-brand fw-bold" href="/">⚡ EV App</a></div>
  </nav>

  <div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-sm border-0 p-4 bg-white rounded-4" style="max-width: 500px; width: 100%;">
      <h3 class="text-center mb-4 text-dark fw-bold">Reschedule Charging</h3>
      <!-- [CYRUS - VALIDATION FEEDBACK] -->
      <% if (
        locals.validationErrors && validationErrors.length > 0
      ) { %>
        <div class="alert alert-danger text-center" role="alert">
          <%= validationErrors[0] %>
        </div>
      <% } %>
      <form action="/rescheduleCharging/<%= chargingSession.sessionId %>" method="POST">
        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Select Station</label>
          <select name="stationId" class="form-select rounded-3 py-2" required>
            <% for(let i=0; i<stations.length; i++) { %>
              <option value="<%= stations[i].stationId %>" <%= chargingSession.stationId === stations[i].stationId ? 'selected' : '' %>>
                <%= stations[i].stationName %> - <%= stations[i].location %>
              </option>
            <% } %>
          </select>
        </div>

        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Scheduled Date & Time</label>
          <input type="datetime-local" class="form-control rounded-3 py-2" name="scheduledDate" value="<%= new Date(chargingSession.scheduledDate).toISOString().slice(0,16) %>" required>
        </div>

        <div class="mb-4">
          <label class="form-label text-muted small fw-semibold">Status</label>
          <select name="status" class="form-select rounded-3 py-2" required>
            <option value="scheduled" <%= chargingSession.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
            <option value="completed" <%= chargingSession.status === 'completed' ? 'selected' : '' %>>Completed</option>
            <option value="cancelled" <%= chargingSession.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-dark rounded-3 py-2 fw-semibold">Update Session</button>
          <a href="/dashboard" class="btn btn-outline-secondary rounded-3 py-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>