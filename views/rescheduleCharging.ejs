<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">EV App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="text-center mb-4">Reschedule Charging Session</h2>

    <% if (chargingSession) { %>
      <form action="/rescheduleCharging/<%= chargingSession.sessionId %>" method="POST" class="mx-auto" style="max-width: 500px;">

        <div class="mb-3">
          <label class="form-label">Vehicle</label>
          <input type="text" class="form-control" value="<%= chargingSession.model %>" readonly>
        </div>

        <div class="mb-3">
          <label for="stationId" class="form-label">Station</label>
          <select id="stationId" name="stationId" class="form-control" required>
            <% for(let i = 0; i < stations.length; i++) { %>
              <option value="<%= stations[i].stationId %>"
                <% if (stations[i].stationId === chargingSession.stationId) { %> selected <% } %>>
                <%= stations[i].stationName %> - <%= stations[i].location %>
              </option>
            <% } %>
          </select>
        </div>

        <div class="mb-3">
          <label for="scheduledDate" class="form-label">Scheduled Date & Time</label>
          <input type="datetime-local" class="form-control" id="scheduledDate" name="scheduledDate" required>
        </div>

        <div class="mb-4">
          <label for="status" class="form-label">Status</label>
          <select id="status" name="status" class="form-control" required>
            <option value="scheduled" <% if (chargingSession.status === 'scheduled') { %> selected <% } %>>Scheduled</option>
            <option value="completed" <% if (chargingSession.status === 'completed') { %> selected <% } %>>Completed</option>
            <option value="cancelled" <% if (chargingSession.status === 'cancelled') { %> selected <% } %>>Cancelled</option>
          </select>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-primary">Update Session</button>
          <a href="/dashboard" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    <% } else { %>
      <p class="text-center">No session found.</p>
    <% } %>
  </div>
</body>
</html>
