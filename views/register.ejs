<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Register</title>
</head>
<body class="bg-light">
  <div class="container d-flex justify-content-center align-items-center my-5">
    <div class="card shadow-sm border-0 p-4 bg-white rounded-4" style="max-width: 480px; width: 100%;">
      <h3 class="text-center mb-4 text-dark fw-bold">Create Account</h3>

      <% if (locals.messages && messages.length > 0) { %>
        <div class="alert alert-danger py-2 text-center small"><%= messages %></div>
      <% } %>

      <form action="/register" method="POST">
        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Username</label>
          <input type="text" class="form-control rounded-3 py-2" name="username" value="<%= locals.formData ? formData.username : '' %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Email</label>
          <input type="email" class="form-control rounded-3 py-2" name="email" value="<%= locals.formData ? formData.email : '' %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Password (min 6 characters)</label>
          <input type="password" class="form-control rounded-3 py-2" name="password" required>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small fw-semibold">Contact Number</label>
          <input type="text" class="form-control rounded-3 py-2" name="contact" value="<%= locals.formData ? formData.contact : '' %>" required>
        </div>
        <div class="mb-4">
          <label class="form-label text-muted small fw-semibold">Role</label>
          <select name="role" class="form-select rounded-3 py-2" required>
            <option value="user">User</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-dark rounded-3 py-2 fw-semibold">Register</button>
        </div>
      </form>
      <div class="text-center mt-3">
        <small class="text-muted">Already have an account? <a href="/login" class="text-dark fw-semibold">Login</a></small>
      </div>
    </div>
  </div>
</body>
</html>