<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">EV App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="text-center mb-4">Book a Charging Session</h2>

    <% if (vehicles.length === 0) { %>
      <p class="text-center">You need to <a href="/addVehicle">add a vehicle</a> first before booking a session.</p>
    <% } else if (stations.length === 0) { %>
      <p class="text-center">No charging stations are currently available.</p>
    <% } else { %>
      <form action="/bookCharging" method="POST" class="mx-auto" style="max-width: 500px;">

        <div class="mb-3">
          <label for="vehicleId" class="form-label">Select Vehicle</label>
          <select id="vehicleId" name="vehicleId" class="form-control" required>
            <% for(let i = 0; i < vehicles.length; i++) { %>
              <option value="<%= vehicles[i].vehicleId %>"><%= vehicles[i].model %> (<%= vehicles[i].plateNumber %>)</option>
            <% } %>
          </select>
        </div>

        <div class="mb-3">
          <label for="stationId" class="form-label">Select Station</label>
          <select id="stationId" name="stationId" class="form-control" required>
            <% for(let i = 0; i < stations.length; i++) { %>
              <option value="<%= stations[i].stationId %>"><%= stations[i].stationName %> - <%= stations[i].location %></option>
            <% } %>
          </select>
        </div>

        <div class="mb-4">
          <label for="scheduledDate" class="form-label">Scheduled Date & Time</label>
          <input type="datetime-local" class="form-control" id="scheduledDate" name="scheduledDate" required>
        </div>

        <div class="d-grid">
          <button type="submit" class="btn btn-primary">Book Session</button>
        </div>

      </form>
    <% } %>
  </div>
</body>
</html>
