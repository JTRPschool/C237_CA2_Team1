<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">EV App</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/dashboard">Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">Logout</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="text-center mb-4">Add New Vehicle</h2>
    <form action="/addVehicle" method="POST" enctype="multipart/form-data" class="mx-auto" style="max-width: 500px;">

      <div class="mb-3">
        <label for="model" class="form-label">Model</label>
        <input type="text" class="form-control" id="model" name="model" placeholder="e.g. Tesla Model 3" required>
      </div>

      <div class="mb-3">
        <label for="plateNumber" class="form-label">Plate Number</label>
        <input type="text" class="form-control" id="plateNumber" name="plateNumber" placeholder="e.g. SGX1234A" required>
      </div>

      <div class="mb-3">
        <label for="batteryHealth" class="form-label">Current Battery Health (%)</label>
        <input type="number" class="form-control" id="batteryHealth" name="batteryHealth" min="0" max="100" step="1" required>
      </div>

      <div class="mb-3">
        <label for="mileage" class="form-label">Current Mileage (km)</label>
        <input type="number" class="form-control" id="mileage" name="mileage" min="0" step="1" required>
      </div>

      <div class="mb-4">
        <label for="image" class="form-label">Vehicle Image (optional)</label>
        <input class="form-control" type="file" id="image" name="image" accept="image/*">
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-primary">Add Vehicle</button>
      </div>

    </form>
  </div>
</body>
</html>
