<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Bootstrap Light Background Card   -->
<!-- [FUNCTIONAL LOGIC] - POST data to /addVehicle via Multer -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App - Add Vehicle</title>
</head>
<body class="bg-light">
  <!-- [AESTHETIC] Sleek Dark Header Navbar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App</a>
      <div class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- [DESIGN] Centered Container Card Wrapper -->
  <div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-sm border-0 p-4 bg-white rounded-4" style="max-width: 500px; width: 100%;">
      <h3 class="text-center mb-4 text-dark fw-bold">Add New Vehicle</h3>
      
      <!-- [FUNCTION] Form Submission Handler -->
      <form action="/addVehicle" method="POST" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="model" class="form-label text-muted small fw-semibold">Vehicle Model</label>
          <input type="text" class="form-control rounded-3 py-2" id="model" name="model" placeholder="e.g. Tesla Model 3" required>
        </div>

        <div class="mb-3">
          <label for="plateNumber" class="form-label text-muted small fw-semibold">Plate Number</label>
          <input type="text" class="form-control rounded-3 py-2" id="plateNumber" name="plateNumber" placeholder="e.g. SGX1234A" required>
        </div>

        <div class="mb-3">
          <label for="batteryHealth" class="form-label text-muted small fw-semibold">Battery Health (%)</label>
          <input type="number" class="form-control rounded-3 py-2" id="batteryHealth" name="batteryHealth" min="0" max="100" step="1" required>
        </div>

        <div class="mb-3">
          <label for="mileage" class="form-label text-muted small fw-semibold">Mileage (km)</label>
          <input type="number" class="form-control rounded-3 py-2" id="mileage" name="mileage" min="0" step="1" required>
        </div>

        <div class="mb-4">
          <label for="image" class="form-label text-muted small fw-semibold">Vehicle Image (Optional)</label>
          <input class="form-control rounded-3 py-2" type="file" id="image" name="image" accept="image/*">
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-dark rounded-3 py-2 fw-semibold">Add Vehicle</button>
          <a href="/dashboard" class="btn btn-outline-secondary rounded-3 py-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>