<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Centered Card Input Layout        -->
<!-- [FUNCTIONAL LOGIC] - POST data to /addBatteryLog/:id     -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App - Add Battery Log</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App</a>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-sm border-0 p-4 bg-white rounded-4" style="max-width: 500px; width: 100%;">
      <h3 class="text-center mb-2 text-dark fw-bold">Add Battery Log</h3>
      <p class="text-center text-muted small mb-4">Vehicle: <strong><%= vehicle.model %></strong></p>

      <form action="/addBatteryLog/<%= vehicle.vehicleId %>" method="POST">
        <div class="mb-3">
          <label for="batteryHealth" class="form-label text-muted small fw-semibold">Battery Health (%)</label>
          <input type="number" class="form-control rounded-3 py-2" id="batteryHealth" name="batteryHealth" min="0" max="100" step="1" required>
        </div>

        <div class="mb-3">
          <label for="mileage" class="form-label text-muted small fw-semibold">Current Mileage (km)</label>
          <input type="number" class="form-control rounded-3 py-2" id="mileage" name="mileage" min="0" step="1" required>
        </div>

        <div class="mb-4">
          <label for="logDate" class="form-label text-muted small fw-semibold">Log Date</label>
          <input type="date" class="form-control rounded-3 py-2" id="logDate" name="logDate" required>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-dark rounded-3 py-2 fw-semibold">Save Log</button>
          <a href="/vehicle/<%= vehicle.vehicleId %>" class="btn btn-outline-secondary rounded-3 py-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>