<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV Management App</title>
</head>
<body class="bg-light d-flex flex-column min-vh-100">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App</a>
      <div class="ms-auto">
        <% if (user) { %>
          <a href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>" class="btn btn-outline-light btn-sm">Dashboard</a>
          <a href="/logout" class="btn btn-danger btn-sm ms-2">Logout</a>
        <% } else { %>
          <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
          <a href="/register" class="btn btn-light btn-sm ms-2">Register</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container d-flex flex-column justify-content-center align-items-center my-auto text-center py-5">
    <div class="card shadow-sm border-0 p-5 bg-white rounded-4" style="max-width: 650px; width: 100%;">
      <h1 class="display-5 fw-bold text-dark mb-3">Electric Vehicle Management</h1>
      <p class="text-muted mb-4">Manage your EV fleet, track battery health logs, and schedule charging station slots seamlessly.</p>
      
      <% if (!user) { %>
        <div class="d-flex justify-content-center gap-3">
          <a href="/login" class="btn btn-dark px-4 py-2 rounded-3 fw-semibold">Login</a>
          <a href="/register" class="btn btn-outline-dark px-4 py-2 rounded-3 fw-semibold">Register</a>
        </div>
      <% } else { %>
        <div>
          <a href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>" class="btn btn-dark px-4 py-2 rounded-3 fw-semibold">Go to Dashboard</a>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>