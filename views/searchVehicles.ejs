<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Filter Card & Data Table Layout   -->
<!-- [FUNCTIONAL LOGIC] - Handles query parameters search/sort-->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Search Vehicles</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App</a>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>">Dashboard</a></li>
      </ul>
    </div>
  </nav>

  <div class="container mt-4 mb-5">
    <h2 class="mb-4 fw-bold text-dark">Search & Filter Fleet</h2>

    <!-- [DESIGN] Filter Criteria Input Card -->
    <div class="card shadow-sm border-0 rounded-4 p-4 bg-white mb-4">
      <form action="/searchVehicles" method="GET" class="row g-3">
        <div class="col-md-4">
          <label class="form-label text-muted small fw-semibold">Keyword Search</label>
          <input type="text" class="form-control rounded-3 py-2" name="search" value="<%= search %>" placeholder="Model or plate number">
        </div>
        <div class="col-md-3">
          <label class="form-label text-muted small fw-semibold">Battery Health</label>
          <select name="batteryFilter" class="form-select rounded-3 py-2">
            <option value="">All Health Levels</option>
            <option value="high" <%= batteryFilter === 'high' ? 'selected' : '' %>>High (&ge; 90%)</option>
            <option value="medium" <%= batteryFilter === 'medium' ? 'selected' : '' %>>Medium (80% - 89%)</option>
            <option value="low" <%= batteryFilter === 'low' ? 'selected' : '' %>>Low (&lt; 80%)</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label text-muted small fw-semibold">Sort By</label>
          <select name="sort" class="form-select rounded-3 py-2">
            <option value="model" <%= sort === 'model' ? 'selected' : '' %>>Model (A-Z)</option>
            <option value="healthDesc" <%= sort === 'healthDesc' ? 'selected' : '' %>>Battery Health (High to Low)</option>
            <option value="healthAsc" <%= sort === 'healthAsc' ? 'selected' : '' %>>Battery Health (Low to High)</option>
            <option value="mileageDesc" <%= sort === 'mileageDesc' ? 'selected' : '' %>>Mileage (High to Low)</option>
            <option value="mileageAsc" <%= sort === 'mileageAsc' ? 'selected' : '' %>>Mileage (Low to High)</option>
          </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button type="submit" class="btn btn-dark w-100 rounded-3 py-2 fw-semibold">Filter</button>
        </div>
      </form>
    </div>

    <!-- [FUNCTION] Results Data Table View -->
    <div class="card shadow-sm border-0 rounded-4 p-3 bg-white">
      <% if (vehicles.length === 0) { %>
        <p class="text-muted text-center py-3 mb-0">No matching vehicles found.</p>
      <% } else { %>
        <table class="table align-middle mb-0">
          <thead>
            <tr>
              <% if(user.role === 'admin') { %><th>Owner</th><% } %>
              <th>Model</th>
              <th>Plate Number</th>
              <th>Battery Health</th>
              <th>Mileage</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% for(let i=0; i<vehicles.length; i++) { %>
              <tr>
                <% if(user.role === 'admin') { %><td><%= vehicles[i].username %></td><% } %>
                <td><%= vehicles[i].model %></td>
                <td><%= vehicles[i].plateNumber %></td>
                <td><%= vehicles[i].batteryHealth %>%</td>
                <td><%= vehicles[i].mileage %> km</td>
                <td><a href="/vehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-dark">View Profile</a></td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</body>
</html>