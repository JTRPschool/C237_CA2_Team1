<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App - Search</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">EV App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <% if (user.role === 'admin') { %>
                <a class="nav-link" href="/adminDashboard">Dashboard</a>
              <% } else { %>
                <a class="nav-link" href="/dashboard">Dashboard</a>
              <% } %>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container mt-3">
    <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
    <div class="text-center"><h2>Search Vehicles</h2></div>
    <p class="text-center text-muted small">
      <% if (user.role === 'admin') { %>
        You can search across the entire fleet.
      <% } else { %>
        You can only search your own vehicles.
      <% } %>
    </p>

    <form action="/searchVehicles" method="GET" class="mx-auto mb-4" style="max-width: 800px;">
      <div class="row">
        <div class="col-md-4 mb-2">
          <label for="search" class="form-label">Model or Plate Number</label>
          <input type="text" class="form-control" id="search" name="search" value="<%= search %>" placeholder="e.g. Tesla or SGX1234">
        </div>
        <div class="col-md-4 mb-2">
          <label for="batteryFilter" class="form-label">Battery Health</label>
          <select id="batteryFilter" name="batteryFilter" class="form-control">
            <option value="" <% if (batteryFilter === '') { %> selected <% } %>>All</option>
            <option value="high" <% if (batteryFilter === 'high') { %> selected <% } %>>High (90% and above)</option>
            <option value="medium" <% if (batteryFilter === 'medium') { %> selected <% } %>>Medium (80% - 89%)</option>
            <option value="low" <% if (batteryFilter === 'low') { %> selected <% } %>>Low (below 80%)</option>
          </select>
        </div>
        <div class="col-md-4 mb-2">
          <label for="sort" class="form-label">Sort By</label>
          <select id="sort" name="sort" class="form-control">
            <option value="" <% if (sort === '') { %> selected <% } %>>Model (A-Z)</option>
            <option value="healthDesc" <% if (sort === 'healthDesc') { %> selected <% } %>>Battery Health (High to Low)</option>
            <option value="healthAsc" <% if (sort === 'healthAsc') { %> selected <% } %>>Battery Health (Low to High)</option>
            <option value="mileageDesc" <% if (sort === 'mileageDesc') { %> selected <% } %>>Mileage (High to Low)</option>
            <option value="mileageAsc" <% if (sort === 'mileageAsc') { %> selected <% } %>>Mileage (Low to High)</option>
          </select>
        </div>
      </div>
      <div class="text-center mt-3">
        <button type="submit" class="btn btn-primary">Search</button>
        <a href="/searchVehicles" class="btn btn-secondary">Reset</a>
      </div>
    </form>

    <div class="text-center"><h3>Results (<%= vehicles.length %>)</h3></div>
    <% if (vehicles.length === 0) { %>
      <p class="text-center">No vehicles match your search.</p>
    <% } else { %>
      <table class="table table-hover small text-center">
        <thead>
            <tr>
              <% if (user.role === 'admin') { %><th>Owner</th><% } %>
              <th>Model</th>
              <th>Plate Number</th>
              <th>Battery Health</th>
              <th>Mileage (km)</th>
            </tr>
        </thead>
        <tbody>
          <% for(let i = 0; i < vehicles.length; i++) { %>
            <tr>
              <% if (user.role === 'admin') { %><td><%= vehicles[i].username %></td><% } %>
              <td><a href="/vehicle/<%= vehicles[i].vehicleId %>"><%= vehicles[i].model %></a></td>
              <td><%= vehicles[i].plateNumber %></td>
              <td>
                <div class="progress" style="height: 20px;">
                  <div class="progress-bar
                    <% if (vehicles[i].batteryHealth >= 90) { %>bg-success
                    <% } else if (vehicles[i].batteryHealth >= 80) { %>bg-warning
                    <% } else { %>bg-danger<% } %>"
                    role="progressbar"
                    style="width: <%= vehicles[i].batteryHealth %>%;">
                    <%= vehicles[i].batteryHealth %>%
                  </div>
                </div>
              </td>
              <td><%= vehicles[i].mileage %></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
