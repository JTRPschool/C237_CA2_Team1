<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Warning Modal Card Layout         -->
<!-- [FUNCTIONAL LOGIC] - Submits POST request to remove entity-->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Delete Vehicle</title>
</head>
<body class="bg-light">
  <!-- [DESIGN] Centered Warning Box -->
  <div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm border-0 p-4 text-center bg-white rounded-4" style="max-width: 420px; width: 100%;">
      <div class="mb-3 text-danger fs-1">⚠️</div>
      <h3 class="fw-bold mb-2 text-dark">Delete Vehicle?</h3>
      <p class="text-muted small mb-4">Are you sure you want to delete <strong><%= vehicle.model %></strong>? This will remove the vehicle along with its related history logs[cite: 1].</p>
      
      <!-- [FUNCTION] Deletion Form Route Handler -->
      <form action="/deleteVehicle/<%= vehicle.vehicleId %>" method="POST">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-danger rounded-3 py-2 fw-semibold">Yes, Delete</button>
          <a href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>" class="btn btn-outline-secondary rounded-3 py-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>