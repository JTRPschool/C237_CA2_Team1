<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark"><div class="container-fluid"><a class="navbar-brand" href="/">EV App</a></div></nav>
  <div class="container mt-4 mx-auto text-center" style="max-width: 500px;">
    <h2 class="text-danger mb-4">Delete Vehicle</h2>
    <p>Are you sure you want to delete <strong><%= vehicle.model %></strong>?</p>
    
    <form action="/deleteVehicle/<%= vehicle.vehicleId %>" method="POST">
      <div class="d-grid gap-2 mt-4">
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <!-- Dynamically checks if the logged-in user is an admin to send them back to the right dashboard -->
        <a href="<%= user.role === 'admin' ? '/adminDashboard' : '/dashboard' %>" class="btn btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>