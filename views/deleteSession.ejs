<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Warning Modal Box Layout          -->
<!-- [FUNCTIONAL LOGIC] - Submits POST request to cancel slot -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Cancel Session</title>
</head>
<body class="bg-light">
  <div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm border-0 p-4 text-center bg-white rounded-4" style="max-width: 420px; width: 100%;">
      <div class="mb-3 text-warning fs-1">⚠️</div>
      <h3 class="fw-bold mb-2 text-dark">Cancel Charging Session</h3>
      <p class="text-muted small mb-4">Are you sure you want to cancel this scheduled charging slot?</p>
      
      <form action="/deleteSession/<%= session.sessionId %>" method="POST">
        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-danger rounded-3 py-2 fw-semibold">Yes, Cancel Session</button>
          <a href="/dashboard" class="btn btn-outline-secondary rounded-3 py-2">Keep Session</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>