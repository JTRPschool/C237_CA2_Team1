<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Admin Charging Station Form Card  -->
<!-- [FUNCTIONAL LOGIC] - POST data to /addStation route      -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App - Add Station</title>
</head>
<body class="bg-light">
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App (Admin)</a>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/adminDashboard">Admin Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-danger" href="/logout">Logout</a></li>
      </ul>
    </div>
  </nav>

  <div class="container d-flex justify-content-center align-items-center mt-5 mb-5">
    <div class="card shadow-sm border-0 p-4 bg-white rounded-4" style="max-width: 500px; width: 100%;">
      <h3 class="text-center mb-4 text-dark fw-bold">Add Charging Station</h3>

      <form action="/addStation" method="POST">
        <div class="mb-3">
          <label for="stationName" class="form-label text-muted small fw-semibold">Station Name</label>
          <input type="text" class="form-control rounded-3 py-2" id="stationName" name="stationName" placeholder="e.g. RP Charging Hub 1" required>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label text-muted small fw-semibold">Location</label>
          <input type="text" class="form-control rounded-3 py-2" id="location" name="location" placeholder="e.g. North Block Basement" required>
        </div>

        <div class="mb-4">
          <label for="available" class="form-label text-muted small fw-semibold">Available Status</label>
          <select id="available" name="available" class="form-select rounded-3 py-2" required>
            <option value="yes">Yes</option>
            <option value="no">No</option>
          </select>
        </div>

        <div class="d-grid gap-2">
          <button type="submit" class="btn btn-dark rounded-3 py-2 fw-semibold">Add Station</button>
          <a href="/adminDashboard" class="btn btn-outline-secondary rounded-3 py-2">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>