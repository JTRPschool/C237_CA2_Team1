<!-- ======================================================== -->
<!-- [DESIGN & AESTHETIC] - Clean Layout Cards & Grid System  -->
<!-- [FUNCTIONAL LOGIC] - Dynamically renders User Vehicles    -->
<!-- ======================================================== -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <title>EV App - Dashboard</title>
</head>
<body class="bg-light">
  <!-- [AESTHETIC] Top Navigation Bar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark shadow-sm px-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/">⚡ EV App Dashboard</a>
      <div class="ms-auto">
        <a href="/searchVehicles" class="btn btn-outline-light btn-sm me-2">🔍 Search Vehicles</a>
        <a href="/logout" class="btn btn-danger btn-sm">Logout</a>
      </div>
    </div>
  </nav>

  <!-- [DESIGN] Main Container Body -->
  <div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>Welcome, <%= user.username %></h2>
      <div>
        <a href="/addVehicle" class="btn btn-dark btn-sm fw-semibold">➕ Add Vehicle</a>
        <a href="/bookCharging" class="btn btn-outline-dark btn-sm fw-semibold ms-2">📅 Book Charging</a>
      </div>
    </div>

    <!-- [FUNCTION] Vehicles Cards Grid Loop -->
    <h4 class="mb-3 text-secondary">My Vehicles</h4>
    <div class="row">
      <% if (vehicles.length === 0) { %>
        <p class="text-muted">No vehicles added yet.</p>
      <% } else { %>
        <% for(let i=0; i<vehicles.length; i++) { %>
          <div class="col-md-4 mb-3">
            <div class="card shadow-sm border-0 rounded-4 p-3 bg-white">
              <% if (vehicles[i].image) { %>
                <img src="/images/<%= vehicles[i].image %>" class="card-img-top rounded-3 mb-2" style="height: 160px; object-fit: cover;" alt="Vehicle">
              <% } %>
              <h5 class="fw-bold"><%= vehicles[i].model %></h5>
              <p class="text-muted small mb-1">Plate: <%= vehicles[i].plateNumber %></p>
              <p class="text-muted small mb-1">Battery Health: <%= vehicles[i].batteryHealth %>%</p>
              <p class="text-muted small mb-3">Mileage: <%= vehicles[i].mileage %> km</p>
              <div class="d-flex gap-2">
                <a href="/vehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-dark flex-grow-1">View Logs</a>
                <a href="/deleteVehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-outline-danger">Delete</a>
              </div>
            </div>
          </div>
        <% } %>
      <% } %>
    </div>

    <!-- [FUNCTION] Scheduled Charging Sessions Table -->
    <h4 class="mt-4 mb-3 text-secondary">Scheduled Charging Sessions</h4>
    <div class="card shadow-sm border-0 rounded-4 p-3 bg-white">
      <% if (sessions.length === 0) { %>
        <p class="text-muted mb-0">No charging sessions scheduled.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th>Vehicle</th>
                <th>Station</th>
                <th>Scheduled Date</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% for(let i=0; i<sessions.length; i++) { %>
                <tr>
                  <td><%= sessions[i].model %></td>
                  <td><%= sessions[i].stationName %></td>
                  <td><%= new Date(sessions[i].scheduledDate).toLocaleString() %></td>
                  <td><span class="badge bg-secondary"><%= sessions[i].status %></span></td>
                  <td>
                    <a href="/rescheduleCharging/<%= sessions[i].sessionId %>" class="btn btn-sm btn-outline-primary">Reschedule</a>
                    <a href="/deleteSession/<%= sessions[i].sessionId %>" class="btn btn-sm btn-outline-danger">Cancel</a>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>