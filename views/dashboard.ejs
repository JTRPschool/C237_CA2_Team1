<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>EV App</title>
</head>
<body>
    <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">EV App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addVehicle">Add Vehicle</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/bookCharging">Book Charging</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/searchVehicles">Search Vehicles</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/logout">Logout</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

  <div class="container">
    <p class="mt-3">Welcome, <%= user.username %> (<%= user.role %>)</p>

    <div class="text-center"><h2>My Vehicles</h2></div>
    <br>
    <% if (vehicles.length === 0) { %>
      <p class="text-center">No vehicles registered yet. <a href="/addVehicle">Add one now</a>.</p>
    <% } else { %>
      <table class="table table-hover small text-center">
        <thead>
            <tr>
              <th>Model</th>
              <th>Plate Number</th>
              <th>Battery Health</th>
              <th>Mileage (km)</th>
              <th>Actions</th>
            </tr>
        </thead>
        <tbody>
          <% for(let i = 0; i < vehicles.length; i++) { %>
            <tr>
              <td><a href="/vehicle/<%= vehicles[i].vehicleId %>"><%= vehicles[i].model %></a></td>
              <td><%= vehicles[i].plateNumber %></td>
              <td>
                <div class="progress" style="height: 20px;">
                  <div class="progress-bar
                    <% if (vehicles[i].batteryHealth >= 90) { %>bg-success
                    <% } else if (vehicles[i].batteryHealth >= 80) { %>bg-warning
                    <% } else { %>bg-danger<% } %>"
                    role="progressbar"
                    style="width: <%= vehicles[i].batteryHealth %>%;">
                    <%= vehicles[i].batteryHealth %>%
                  </div>
                </div>
              </td>
              <td><%= vehicles[i].mileage %></td>
              <td>
                <a href="/addBatteryLog/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-primary">Log Battery</a>
                <a href="/deleteVehicle/<%= vehicles[i].vehicleId %>" class="btn btn-sm btn-danger">Delete</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>

    <br>
    <div class="text-center"><h2>My Charging Sessions</h2></div>
    <br>
    <% if (sessions.length === 0) { %>
      <p class="text-center">No charging sessions scheduled. <a href="/bookCharging">Book one now</a>.</p>
    <% } else { %>
      <table class="table table-hover small text-center">
        <thead>
            <tr>
              <th>Vehicle</th>
              <th>Station</th>
              <th>Scheduled Date</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
        </thead>
        <tbody>
          <% for(let i = 0; i < sessions.length; i++) { %>
            <tr>
              <td><%= sessions[i].model %></td>
              <td><%= sessions[i].stationName %></td>
              <td><%= sessions[i].scheduledDate %></td>
              <td><%= sessions[i].status %></td>
              <td>
                <a href="/rescheduleCharging/<%= sessions[i].sessionId %>" class="btn btn-sm btn-warning">Reschedule</a>
                <a href="/deleteSession/<%= sessions[i].sessionId %>" class="btn btn-sm btn-danger">Cancel</a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </div>
</body>
</html>
